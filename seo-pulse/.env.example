# ─── Supabase ────────────────────────────────────────────────────────────
# Get these at https://supabase.com/dashboard → Project Settings → API
# VITE_SUPABASE_URL is your project URL (ends with .supabase.co)
# VITE_SUPABASE_ANON_KEY is the public anon key (safe to expose to browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────
# Test or Live publishable key from https://dashboard.stripe.com/apikeys
# Prefix: pk_test_* or pk_live_*
VITE_STRIPE_PUBLISHABLE_KEY=

# ─── Server-side secrets (never exposed to browser) ────────────────────────

# Stripe secret key from https://dashboard.stripe.com/apikeys
# Prefix: sk_test_* or sk_live_*
STRIPE_SECRET_KEY=

# Anthropic Claude API key from https://console.anthropic.com/
# Used for content analysis, SEO insights, and report generation
CLAUDE_API_KEY=

# Brave Search API key from https://brave.com/search/api/
# Used for competitor website indexing and keyword research
BRAVE_SEARCH_API_KEY=

# DataForSEO credentials from https://dataforseo.com/
# Used for rank tracking, keyword volume, and SERP analysis
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
