# Janus Demo — Environment Variables
# Copy to .env and fill in your values

# ── Backend (Flask) ──────────────────────────────────────────────
# URL of the inference server (YOLO/Roboflow)
INFERENCE_URL=http://localhost:8002

# ── Edge Agent ───────────────────────────────────────────────────
# Backend URL for posting events/sessions
JANUS_BACKEND=http://localhost:8000

# YOLO model file (e.g. yolov8n.pt, yolo11l.pt)
YOLO_MODEL=yolov8n.pt

# Minimum detection confidence (0.0-1.0)
CONF=0.35

# Inference device: cpu, cuda, mps
DEVICE=cpu

# Aggregation interval in seconds
AGG_INTERVAL=60

# ── Roboflow Cloud Pipeline ─────────────────────────────────────
# Required for pre-processed (offline) tracking pipeline
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL=people-detection-o4rdr/4

# ── Video Streamer ───────────────────────────────────────────────
# Inference mode: cloud (Roboflow) or local (YOLO)
INFERENCE_MODE=cloud
