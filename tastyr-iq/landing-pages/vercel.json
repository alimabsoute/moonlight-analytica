{
  "rewrites": [
    { "source": "/", "destination": "/fork-landing-cinematic.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/support", "destination": "/support/index.html" },
    { "source": "/the-dish", "destination": "/the-dish/index.html" },
    { "source": "/the-dish/(.*)", "destination": "/the-dish/$1" },
    { "source": "/the-dish/rss.xml", "destination": "/the-dish/rss.xml" },
    { "source": "/carte", "destination": "/carte/index.html" },
    { "source": "/carte/(.*)", "destination": "/carte/$1" },
    { "source": "/socials", "destination": "/socials/index.html" },
    { "source": "/restaurants", "destination": "/restaurants/index.html" },
    { "source": "/gallery", "destination": "/gallery/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*\\.png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.jpg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
